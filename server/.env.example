PORT=5000
BACKEND_PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/fee-collection
JWT_SECRET=your-secret-change-in-production
JWT_EXPIRES_IN=7d

# ISO 3166-1 alpha-2: used to parse local phone numbers without + prefix
PHONE_DEFAULT_REGION=IN

# Razorpay (https://dashboard.razorpay.com/)
# Webhook URL: https://YOUR_PUBLIC_HOST/payments/webhook
# Tunnel the API port (e.g. ngrok http 3000), not the Vite dev server port.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Secret from Dashboard → Webhooks → your endpoint (NOT the Key Secret above)
RAZORPAY_WEBHOOK_SECRET=
# Optional: redirect after Payment Link checkout
# PAYMENT_LINK_CALLBACK_URL=

# Public API base URL for SMS pay links (no trailing slash), e.g. https://your-api.example.com
PUBLIC_APP_URL=http://localhost:5173

# Optional: POST /internal/reminders/run — header X-Cron-Secret must match
CRON_SECRET=

# SMS: use "console" to log only, or "twilio" with credentials below
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=US36c5bea3741ce49378837acb3036df47
TWILIO_AUTH_TOKEN=AC9e48b9b72a2a11beb50ade0176249743:787f334c42089e87ac36bf1a2b837ee1
TWILIO_FROM_NUMBER=US36c5bea3741ce49378837acb3036df47
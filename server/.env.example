PORT=5000
BACKEND_PORT=5001
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/fee-collection
JWT_SECRET=SECRET_KEY_CHANGE_IN_PRODUCTION
JWT_EXPIRES_IN=7d

# ISO 3166-1 alpha-2: used to parse local phone numbers without + prefix
PHONE_DEFAULT_REGION=IN

# Razorpay (https://dashboard.razorpay.com/)
# Webhook URL: https://YOUR_PUBLIC_HOST/payments/webhook
# Tunnel the API port (e.g. ngrok http 3000), not the Vite dev server port.
RAZORPAY_KEY_ID=EXAMPLE_KEY_ID
RAZORPAY_KEY_SECRET=EXAMPLE_KEY_SECRET
# Secret from Dashboard → Webhooks → your endpoint (NOT the Key Secret above)
RAZORPAY_WEBHOOK_SECRET=EXAMPLE_WEBHOOK_SECRET
# Optional: redirect after Payment Link checkout
# PAYMENT_LINK_CALLBACK_URL=

# Public API base URL for SMS pay links (no trailing slash), e.g. https://your-api.example.com
PUBLIC_APP_URL=http://localhost:5173

# Optional: POST /internal/reminders/run — header X-Cron-Secret must match
CRON_SECRET=

# SMS: use "console" to log only, or "twilio" with credentials below
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=EXAMPLE_SID
TWILIO_AUTH_TOKEN=EXAMPLE_TOKEN
TWILIO_FROM_NUMBER=EXAMPLE_NUMBER

# Landing page — "Book a free demo" emails (nodemailer SMTP)
# Recipient (default below); override if needed
# DEMO_NOTIFICATION_EMAIL=pratik.edigo@gmail.com
# Gmail example: use an App Password (Google Account → Security → App passwords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your.sender@gmail.com
# SMTP_PASS=your_app_password
# Optional From header (defaults to SMTP_USER)
# SMTP_FROM="Edigo <your.sender@gmail.com>"
# API base URL (no trailing slash) — must match your Express server (default port 3000).
VITE_API_URL=http://localhost:8080

# Required in local dev for auth (tenant slug in your database). Optional in production if you use tenant subdomains.
VITE_TENANT_SLUG=nvm-school

# Optional: override production tenant apex (defaults to edigo.in in prod builds).
# VITE_TENANT_ROOT_DOMAIN=edigo.in

# Optional: Google Analytics 4 (G-XXXXXXXXXX). Injected only on the public landing page.
# VITE_GA_MEASUREMENT_ID=
